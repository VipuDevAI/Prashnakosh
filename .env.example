# =============================================================================
# PRASHNAKOSH v1.0 — Production Environment Configuration
# =============================================================================
#
# INSTRUCTIONS:
#   1. Copy this file to .env              copy .env.example .env
#   2. Fill in EVERY value marked (required)
#   3. Run scripts\install.bat
#
# WARNING: Do not commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# GHCR Authentication  (required)
# -----------------------------------------------------------------------------
# GitHub Personal Access Token with read:packages scope.
# Generate at: https://github.com/settings/tokens/new?scopes=read:packages
GHCR_USER=
GHCR_TOKEN=

# -----------------------------------------------------------------------------
# Image Version
# -----------------------------------------------------------------------------
# Docker image tag to pull. "latest" = most recent stable build.
# Pin a release with a version tag (v1.0.0) or commit SHA.
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# Database  (required)
# -----------------------------------------------------------------------------
# Password for the PostgreSQL database created inside Docker.
# Choose a strong password. It never leaves the server.
DB_PASSWORD=

# -----------------------------------------------------------------------------
# Session Security  (required)
# -----------------------------------------------------------------------------
# A random 64-character string used to sign session tokens.
# Generate in PowerShell:
#   -join ((48..57)+(65..90)+(97..122)|Get-Random -Count 64|%{[char]$_})
SESSION_SECRET=

# -----------------------------------------------------------------------------
# Data Directory  (required)
# -----------------------------------------------------------------------------
# Root path on the host where all persistent data is stored:
# database files, uploads, exports, backups, and logs.
# Use a drive with at least 50 GB free space.
DATA_DIR=E:\PrashnakoshData

# -----------------------------------------------------------------------------
# Super Admin Account  (required for first deployment)
# -----------------------------------------------------------------------------
# These credentials create the initial Super Admin user on first startup.
# The account is only created if no Super Admin exists in the database.
# Subsequent restarts will NOT overwrite or recreate this account.
#
# SCHOOL_CODE is the code you enter on the login screen to access Super Admin.
SUPER_ADMIN_SCHOOL_CODE=SUPERADMIN
SUPER_ADMIN_SCHOOL_NAME=Prashnakosh Central
SUPER_ADMIN_EMAIL=admin@prashnakosh.local
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Super Admin
